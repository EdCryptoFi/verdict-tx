# Solana
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=Bw3Ztg8nPBRxVLLtNqCksQNEP4cbv64xbpzr6YHrX7a7

# Wallets / keys (paths to JSON keypair files — NEVER commit the real files)
# Defaults to the Solana CLI key at ~/.config/solana/id.json, so `pnpm sync:daily` needs no setup.
ADMIN_KEYPAIR=~/.config/solana/id.json
# The TxODDS oracle ed25519 signer. Its pubkey is stored on each market as oracle_pubkey.
ORACLE_KEYPAIR=./keypairs/oracle.json

# Settlement token (USDC). Devnet uses a test mint you control.
USDC_MINT=

# TxODDS API
TXODDS_API_BASE=
TXODDS_API_KEY=

# Indexer
INDEXER_PORT=8787
