{
  "name": "verdict",
  "version": "0.1.0",
  "private": true,
  "description": "Verifiable World Cup prediction markets on Solana (TxODDS hackathon)",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test",
    "relayer:dev": "pnpm --filter @verdict/relayer dev",
    "app:dev": "pnpm --filter @verdict/app dev",
    "indexer:dev": "pnpm --filter @verdict/indexer dev",
    "sync:daily": "pnpm --filter @verdict/relayer sync:daily",
    "sync:watch": "pnpm --filter @verdict/relayer sync"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "chai": "^4.5.0",
    "mocha": "^10.8.2",
    "prettier": "^3.4.2",
    "ts-mocha": "^11.1.0",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.12.3"
}
